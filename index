.hof-icon{width:24px;height:24px;color:var(--gold)}
.hof-label{font-family:'Bebas Neue',sans-serif;font-size:18px;font-weight:400;letter-spacing:1.5px;text-transform:uppercase}
.hof-sub{font-size:12px;color:var(--muted);font-weight:300}
.hof-badge{font-family:'Bebas Neue',sans-serif;font-size:10px;font-weight:400;letter-spacing:1.0px;text-transform:uppercase;padding:5px 14px;border:1px solid rgba(255,184,0,.28);color:var(--gold)}
.hof-year{background:rgba(255,255,255,.025);border:1px solid var(--w06);overflow:hidden;margin-bottom:2px}
.hof-yh{background:rgba(255,255,255,.05);padding:12px 22px;display:flex;align-items:center;gap:12px;border-bottom:1px solid var(--w06)}
.hof-ynum{font-family:'Bebas Neue',sans-serif;font-size:22px;font-weight:400;letter-spacing:1.5px;color:var(--gold)}
.hof-ytag{font-size:9px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--muted);padding:2px 8px;border:1px solid var(--w06)}
.hof-empty{padding:48px 40px;text-align:center}
.hof-ei{width:44px;height:44px;color:rgba(255,184,0,.18);margin:0 auto 14px}
.hof-et{font-family:'Bebas Neue',sans-serif;font-size:18px;font-weight:400;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.18);margin-bottom:6px}
.hof-es{font-size:13px;color:var(--muted);font-weight:300;line-height:1.7;max-width:380px;margin:0 auto}
/* legado manifesto */
.manifesto{background:var(--card);border:1px solid rgba(255,184,0,.14);padding:56px;text-align:center;margin-top:2px}
.manifesto-quote{font-family:'Montserrat',sans-serif;font-style:italic;font-size:clamp(18px,3vw,28px);color:rgba(255,255,255,.7);line-height:1.6;max-width:700px;margin:0 auto 24px}
.manifesto-quote::before{content:'\201C'}
.manifesto-quote::after{content:'\201D'}
.manifesto-attr{font-family:'Bebas Neue',sans-serif;font-size:11px;font-weight:400;letter-spacing:2.0px;text-transform:uppercase;color:var(--or)}

/* ── TOAST ── */
.toast{position:fixed;bottom:24px;right:24px;transform:translateY(100px);opacity:0;background:var(--green);color:var(--w);padding:13px 22px;font-family:'Bebas Neue',sans-serif;font-size:13px;font-weight:400;letter-spacing:1.0px;text-transform:uppercase;z-index:9998;transition:all .4s cubic-bezier(.34,1.56,.64,1);display:flex;align-items:center;gap:9px;box-shadow:0 8px 32px rgba(0,192,106,.3)}
.toast.show{transform:translateY(0);opacity:1}
.toast svg{width:16px;height:16px}

/* ── FOOTER ── */
footer{background:rgba(7,7,15,.97);border-top:1px solid rgba(255,92,0,.12);padding:28px 48px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
.fb{display:flex;align-items:center;gap:9px}
.fb svg{width:20px;height:20px;color:var(--or)}
.fb-text{font-family:'Bebas Neue',sans-serif;font-size:16px;font-weight:400;letter-spacing:2.0px;text-transform:uppercase}
.fb-text em{color:var(--or);font-style:normal}
.fc{font-size:11px;color:var(--muted);letter-spacing:1.5px}

/* ── ANIM ── */
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes pulseG{0%,100%{opacity:.6;transform:scale(1)}50%{opacity:1;transform:scale(1.04)}}

@media(max-width:900px){
  .main-nav{overflow-x:auto}
  .pw{padding:56px 20px}
  .cat-hero,.vote-hero{padding:40px 20px}
  .cat-hero-inner{grid-template-columns:1fr;gap:32px}
  .main-cats,.concept-grid,.premio-grid,.nb-pillars{grid-template-columns:1fr}
  .fcats{grid-template-columns:repeat(2,1fr)}
  .vote-layout{grid-template-columns:1fr}
  .vote-sidebar{position:static;display:none}
  .pcards{grid-template-columns:repeat(2,1fr)}
  .vote-step-cards{flex-wrap:wrap}
  .vote-hero-inner{grid-template-columns:1fr;gap:24px}
  footer{padding:24px 20px;flex-direction:column;text-align:center}
}
