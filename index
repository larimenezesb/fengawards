<style>
:root {
  --pu:    #1A0838;
  --pu2:   #2D1456;
  --pu3:   #3D1A72;
  --or:    #FF5C00;
  --or2:   #FF7A22;
  --gold:  #FFB800;
  --gold2: #E8A200;
  --green: #00C06A;
  --silver:#B8C4D8;
  --w:     #FFFFFF;
  --w04:   rgba(60,15,130,0.35);
  --w06:   rgba(255,255,255,0.07);
  --w10:   rgba(255,255,255,0.10);
  --w20:   rgba(255,255,255,0.22);
  --muted: #C09AE8;
  --dark:  #080316;
  --card:  rgba(60,15,130,0.35);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Montserrat',sans-serif;background:var(--dark);color:var(--w);overflow-x:hidden;min-height:100vh}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:9000;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.012) 3px,rgba(0,0,0,0.012) 4px)}

/* ── TICKER ── */
.topbar{background:var(--or);padding:7px 0;overflow:hidden;flex-shrink:0}
.ticker-track{display:flex;width:100%;overflow:hidden}
.ticker-inner{display:flex;gap:60px;white-space:nowrap;animation:ticker 30s linear infinite;font-family:'Bebas Neue',sans-serif;font-size:11px;font-weight:400;letter-spacing:1.2px;text-transform:uppercase;color:var(--w)}
.ticker-inner span{display:flex;align-items:center;gap:10px}
.td{width:5px;height:5px;border-radius:50%;background:var(--w);opacity:.35}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ── MAIN NAV (tabs) ── */
.main-nav{
  position:sticky;top:0;z-index:200;
  background:rgba(7,7,15,0.97);
  border-bottom:1px solid rgba(255,92,0,0.2);
  backdrop-filter:blur(16px);
  display:flex;align-items:stretch;
  flex-shrink:0;
  min-height:68px;
}
.nav-brand{display:flex;align-items:center;gap:12px;text-decoration:none;padding:0 36px;border-right:1px solid var(--w06);flex-shrink:0}
.nb-icon{width:32px;height:32px;color:var(--or)}
.nb-text{font-family:'Bebas Neue',sans-serif;font-size:26px;font-weight:400;letter-spacing:2.5px;text-transform:uppercase}
.nb-text em{color:var(--or);font-style:normal}.nb-feng-word{color:#A855F7}
.nb-year{font-size:9px;font-weight:700;letter-spacing:3px;color:var(--muted);padding:2px 7px;border:1px solid var(--w06);margin-left:4px;align-self:center}
.nav-tabs{display:flex;flex:1;overflow-x:auto;scrollbar-width:none}
.nav-tabs::-webkit-scrollbar{display:none}
.tab-btn{
  display:flex;align-items:center;gap:7px;
  padding:0 22px;
  font-family:'Bebas Neue',sans-serif;
  font-size:12px;font-weight:400;letter-spacing:1.0px;text-transform:uppercase;
  color:var(--muted);background:transparent;border:none;
  border-bottom:3px solid transparent;
  cursor:pointer;transition:all .2s;white-space:nowrap;height:56px;
}
.tab-btn svg{width:15px;height:15px;flex-shrink:0}
.tab-btn:hover{color:var(--w);border-bottom-color:rgba(255,92,0,.35)}
.tab-btn.active{color:var(--or);border-bottom-color:var(--or)}
.tab-badge{background:var(--or);color:var(--w);font-size:8px;font-weight:800;letter-spacing:1px;padding:2px 6px;border-radius:0;animation:pulse-b 2s ease-in-out infinite}
@keyframes pulse-b{0%,100%{opacity:1}50%{opacity:.55}}

/* state toggle (2026/2027) */
.state-toggle{display:flex;align-items:center;gap:0;padding:0 20px;border-left:1px solid var(--w06);flex-shrink:0}
.state-btn{padding:6px 14px;font-family:'Bebas Neue',sans-serif;font-size:10px;font-weight:400;letter-spacing:1.0px;text-transform:uppercase;cursor:pointer;border:1px solid var(--w06);background:transparent;color:var(--muted);transition:all .2s}
.state-btn.on{background:rgba(255,92,0,.15);color:var(--or);border-color:rgba(255,92,0,.3)}
.state-btn:first-child{border-right:none}

/* ── PAGE SHELL ── */
.page{display:none;min-height:calc(100vh - 100px)}
.page.active{display:block}

/* ── SHARED ── */
.pw{max-width:1160px;margin:0 auto;padding:72px 48px}
.s-label{font-family:'Bebas Neue',sans-serif;font-size:10px;font-weight:400;letter-spacing:2.5px;text-transform:uppercase;color:var(--or);margin-bottom:12px;display:flex;align-items:center;gap:10px}
.s-label::before{content:'';width:18px;height:2px;background:var(--or)}
.s-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(34px,5vw,60px);font-weight:400;letter-spacing:1.5px;text-transform:uppercase;line-height:.95;margin-bottom:14px}
.s-lead{font-size:15px;color:rgba(255,255,255,.70);line-height:1.85;max-width:580px;margin-bottom:48px;font-weight:300}
.divider-label{font-family:'Bebas Neue',sans-serif;font-size:10px;font-weight:400;letter-spacing:2.0px;text-transform:uppercase;color:var(--muted);padding:12px 0;border-bottom:1px solid var(--w06);margin-bottom:2px;display:flex;align-items:center;gap:10px}
.divider-label::before{content:'';width:14px;height:2px;background:var(--or);flex-shrink:0}

/* buttons */
.btn-or{background:linear-gradient(135deg,var(--or),#CC4500);color:var(--w);border:none;padding:14px 36px;font-family:'Bebas Neue',sans-serif;font-size:13px;font-weight:400;letter-spacing:1.2px;text-transform:uppercase;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:8px;clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px));transition:all .25s;box-shadow:0 4px 24px rgba(255,92,0,.28)}
.btn-or:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(255,92,0,.45)}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--w);border:none;padding:14px 36px;font-family:'Bebas Neue',sans-serif;font-size:13px;font-weight:400;letter-spacing:1.2px;text-transform:uppercase;cursor:pointer;display:inline-flex;align-items:center;gap:8px;clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px));transition:all .25s;box-shadow:0 4px 24px rgba(255,184,0,.25)}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(255,184,0,.45)}
.btn-ghost{background:transparent;color:var(--muted);border:1px solid var(--w10);padding:14px 36px;font-family:'Bebas Neue',sans-serif;font-size:13px;font-weight:400;letter-spacing:1.2px;text-transform:uppercase;cursor:pointer;text-decoration:none;display:inline-block;transition:all .25s}
.btn-ghost:hover{border-color:rgba(255,92,0,.35);color:var(--or)}

/* ── PAGE 1: SOBRE ── */
#page-sobre .hero{position:relative;overflow:hidden;padding:80px 48px 64px;text-align:center;background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(100,30,200,.25) 0%,transparent 60%),radial-gradient(ellipse 100% 70% at 50% 100%,rgba(255,92,0,.10) 0%,transparent 65%),radial-gradient(ellipse 50% 40% at 75% 15%,rgba(255,92,0,.08) 0%,transparent 55%),linear-gradient(165deg,#1E0845 0%,#080316 55%,#1A0838 100%)}
#page-sobre .hero::before{content:'';position:absolute;inset:0;background-image:repeating-linear-gradient(-55deg,transparent,transparent 100px,rgba(255,255,255,.018) 100px,rgba(255,255,255,.018) 101px)}
.hero-trophy-wrap{position:relative;display:inline-block;margin-bottom:28px}

.hero-kicker{font-family:'Bebas Neue',sans-serif;font-size:10px;font-weight:400;letter-spacing:3.0px;text-transform:uppercase;color:var(--or);margin-bottom:16px}
.hero-h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(68px,12vw,140px);font-weight:400;line-height:.88;letter-spacing:2.5px;text-transform:uppercase}
.hero-h1 em{display:block;font-style:normal;color:transparent;-webkit-text-stroke:2px var(--or);font-size:clamp(40px,7vw,84px);letter-spacing:15px}
.hero-tagline{font-family:'Montserrat',sans-serif;font-style:italic;font-size:clamp(16px,2.5vw,22px);color:var(--muted);margin-top:16px;margin-bottom:28px}
.hero-copy{font-size:16px;color:rgba(255,255,255,.65);line-height:1.9;max-width:560px;margin:0 auto 40px;font-weight:300}
.hero-ctas{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
/* concept blocks */
.concept-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px}
.cblock{background:var(--card);border:1px solid var(--w06);padding:44px 38px;transition:all .35s}
.cblock:hover{border-color:rgba(255,92,0,.18);transform:translateY(-3px)}
.cblock-icon{width:36px;height:36px;color:var(--or);margin-bottom:18px}
.cblock-title{font-family:'Bebas Neue',sans-serif;font-size:26px;font-weight:400;letter-spacing:1.0px;text-transform:uppercase;margin-bottom:10px}
.cblock-body{font-size:14px;color:rgba(255,255,255,.72);line-height:1.8;font-weight:300}
/* timeline */
.timeline{display:flex;flex-direction:column;gap:2px;margin-top:48px}
.tl-item{display:flex;gap:0;background:var(--card);border:1px solid var(--w06);overflow:hidden;transition:all .3s}
.tl-item:hover{border-color:rgba(255,92,0,.18)}
.tl-num{width:72px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:rgba(255,92,0,.07);border-right:1px solid var(--w06)}
.tl-num span{font-family:'Bebas Neue',sans-serif;font-size:36px;font-weight:400;color:rgba(255,92,0,.5)}
.tl-body{padding:24px 28px;flex:1}
.tl-tag{font-family:'Bebas Neue',sans-serif;font-size:9px;font-weight:400;letter-spacing:1.5px;text-transform:uppercase;color:var(--or);margin-bottom:4px}
.tl-title{font-family:'Bebas Neue',sans-serif;font-size:22px;font-weight:400;letter-spacing:1.0px;text-transform:uppercase;margin-bottom:6px}
.tl-desc{font-size:13px;color:rgba(255,255,255,.68);line-height:1.7;font-weight:300}
.tl-badge{display:inline-block;margin-top:10px;font-family:'Bebas Neue',sans-serif;font-size:9px;font-weight:400;letter-spacing:1.0px;text-transform:uppercase;padding:4px 12px;border:1px solid rgba(255,92,0,.22);color:var(--or)}
/* state-aware */
.state-2026{display:block}
.state-2027{display:none}
body.s2027 .state-2026{display:none}
body.s2027 .state-2027{display:block}

/* ── PAGE 2: CATEGORIAS ── */
.cat-hero{background:linear-gradient(135deg,rgba(255,255,255,.025),transparent);border-bottom:1px solid var(--w06);padding:56px 48px 48px}
.cat-hero-inner{max-width:1160px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
/* main cats */
.main-cats{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.mcat{position:relative;overflow:hidden;background:var(--card);border:1px solid var(--w06);padding:40px 32px;transition:all .4s}
.mcat-top{position:absolute;top:0;left:0;right:0;height:4px}
.rel .mcat-top{background:linear-gradient(90deg,var(--or),var(--or2))}
.est .mcat-top{background:linear-gradient(90deg,#9B5CF6,#C084FC)}
.apr .mcat-top{background:linear-gradient(90deg,#A855F7,var(--or))}
.mcat-ghost{position:absolute;right:-8px;bottom:-20px;font-family:'Bebas Neue',sans-serif;font-size:130px;font-weight:400;color:rgba(255,255,255,.025);line-height:1;pointer-events:none}
.mcat:hover{border-color:rgba(255,92,0,.2);background:rgba(255,255,255,.07);transform:translateY(-4px);box-shadow:0 16px 48px rgba(0,0,0,.45)}
.mcat-icon{width:36px;height:36px;color:var(--or);margin-bottom:18px}
.mcat-num{font-family:'Bebas Neue',sans-serif;font-size:10px;font-weight:400;letter-spacing:2.0px;text-transform:uppercase;color:var(--or);margin-bottom:8px}
.mcat-name{font-family:'Bebas Neue',sans-serif;font-size:40px;font-weight:400;letter-spacing:1.0px;text-transform:uppercase;line-height:1;margin-bottom:12px}
.mcat-desc{font-size:13px;color:rgba(255,255,255,.68);line-height:1.75;margin-bottom:18px;font-weight:300}
.mcat-list{list-style:none;display:flex;flex-direction:column;gap:9px}
.mcat-list li{font-size:12px;color:rgba(255,255,255,.72);padding-left:16px;position:relative;line-height:1.5}
.mcat-list li::before{content:'';position:absolute;left:0;top:8px;width:6px;height:2px;background:var(--or);border-radius:1px}
/* special cats */
.fcats{display:grid;grid-template-columns:repeat(4,1fr);gap:2px}
.fcat{background:rgba(255,255,255,.025);border:1px solid var(--w06);padding:22px 18px;position:relative;transition:all .3s}
.fcat-line{position:absolute;top:0;left:0;bottom:0;width:3px;background:linear-gradient(to bottom,var(--or),rgba(255,92,0,.1));opacity:0;transition:opacity .3s}
.fcat:hover{border-color:rgba(255,92,0,.18);background:rgba(255,255,255,.05)}
.fcat:hover .fcat-line{opacity:1}
.fcat-icon{width:26px;height:26px;color:var(--or);margin-bottom:10px;opacity:.7;transition:opacity .3s}
.fcat:hover .fcat-icon{opacity:1}
.fcat-name{font-family:'Bebas Neue',sans-serif;font-size:17px;font-weight:400;letter-spacing:0.5px;text-transform:uppercase;color:var(--or);margin-bottom:3px}
.fcat-sub{font-size:11px;font-style:italic;color:var(--muted);margin-bottom:7px}
.fcat-desc{font-size:12px;color:rgba(255,255,255,.65);line-height:1.6;font-weight:300}

/* ── PAGE 3: VOTAÇÃO ── */
#page-votacao{background:rgba(45,20,86,.04)}
.vote-hero{background:linear-gradient(135deg,rgba(255,255,255,.04),rgba(7,7,15,.6));border-bottom:1px solid var(--w06);padding:52px 48px 44px}
.vote-hero-inner{max-width:1160px;margin:0 auto;display:grid;grid-template-columns:1fr auto;gap:48px;align-items:center}
.vote-step-cards{display:flex;gap:2px}
.vstep{background:rgba(255,255,255,.025);border:1px solid var(--w06);padding:18px 20px;min-width:160px;text-align:center;transition:all .3s}
.vstep.current{border-color:rgba(255,92,0,.35);background:rgba(255,92,0,.08)}
.vstep-num{font-family:'Bebas Neue',sans-serif;font-size:32px;font-weight:400;color:rgba(255,92,0,.3);line-height:1;margin-bottom:4px}
.vstep.current .vstep-num{color:var(--or)}
.vstep-title{font-family:'Bebas Neue',sans-serif;font-size:14px;font-weight:400;letter-spacing:0.8px;text-transform:uppercase;margin-bottom:3px}
.vstep.current .vstep-title{color:var(--or)}
.vstep-sub{font-size:11px;color:var(--muted);font-weight:300}
/* Vote layout — two columns */
.vote-layout{display:grid;grid-template-columns:280px 1fr;gap:2px;align-items:start;margin-top:0}
/* sidebar */
.vote-sidebar{position:sticky;top:56px;background:rgba(255,255,255,.025);border:1px solid var(--w06)}
.vsb-header{padding:18px 20px;border-bottom:1px solid var(--w06);background:rgba(255,255,255,.04)}
.vsb-title{font-family:'Bebas Neue',sans-serif;font-size:14px;font-weight:400;letter-spacing:1.0px;text-transform:uppercase}
.vsb-sub{font-size:11px;color:var(--muted);font-weight:300;margin-top:2px}
.vsb-item{display:flex;align-items:center;gap:10px;padding:11px 18px;border-bottom:1px solid var(--w04);cursor:pointer;transition:all .2s}
.vsb-item:last-child{border-bottom:none}
.vsb-item:hover,.vsb-item.done{background:rgba(255,92,0,.05)}
.vsb-icon{width:16px;height:16px;color:var(--muted);flex-shrink:0;transition:color .2s}
.vsb-item.done .vsb-icon{color:var(--green)}
.vsb-name{font-family:'Bebas Neue',sans-serif;font-size:13px;font-weight:400;letter-spacing:0.5px;text-transform:uppercase;color:rgba(255,255,255,.6);transition:color .2s}
.vsb-item:hover .vsb-name,.vsb-item.done .vsb-name{color:var(--w)}
.vsb-dot{width:8px;height:8px;border-radius:50%;border:1.5px solid rgba(255,255,255,.2);flex-shrink:0;margin-left:auto;transition:all .2s}
.vsb-item.done .vsb-dot{background:var(--green);border-color:var(--green)}
/* vote panels */
.vote-panels{background:rgba(255,255,255,.02);border:1px solid var(--w06)}
.vpanel-header{padding:20px 28px;border-bottom:1px solid var(--w06);background:rgba(255,255,255,.025)}
.vph-tag{font-family:'Bebas Neue',sans-serif;font-size:9px;font-weight:400;letter-spacing:1.5px;text-transform:uppercase;color:var(--or);margin-bottom:3px}
.vph-title{font-family:'Bebas Neue',sans-serif;font-size:20px;font-weight:400;letter-spacing:1.0px;text-transform:uppercase}
.vpanel-body{padding:24px 28px}
/* text input for fase1 */
.fi{display:flex;flex-direction:column;gap:6px;margin-bottom:14px}
.fi label{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted)}
.feng-input{background:rgba(45,20,86,.35);border:1px solid var(--w06);color:var(--w);padding:12px 16px;font-family:'Montserrat',sans-serif;font-size:14px;font-weight:300;width:100%;outline:none;transition:border-color .25s}
.feng-input:focus{border-color:var(--or)}
.feng-input::placeholder{color:var(--muted)}
.feng-ta{resize:vertical;min-height:68px}
.panel-submit{padding:18px 28px;border-top:1px solid var(--w06);display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap}
.panel-note{font-size:12px;color:var(--muted);font-weight:300}
/* player cards fase2 */
.pcards{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.pcard{position:relative;background:rgba(255,255,255,.025);border:1px solid var(--w06);padding:24px 20px;cursor:pointer;transition:all .3s;user-select:none}
.pcard-top{position:absolute;top:0;left:0;right:0;height:3px;background:rgba(255,255,255,.06);transition:background .3s}
.pcard.selected .pcard-top,.pcard:hover .pcard-top{background:linear-gradient(90deg,var(--or),var(--or2))}
.pcard:hover{border-color:rgba(255,92,0,.2);background:rgba(255,255,255,.06)}
.pcard.selected{border-color:rgba(255,92,0,.35);background:rgba(255,255,255,.06);box-shadow:0 0 0 1px rgba(255,92,0,.18),0 8px 28px rgba(0,0,0,.4)}
.pcard input[type=radio]{display:none}
.pcard-avatar{width:46px;height:46px;border-radius:50%;background:rgba(255,255,255,.06);display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:16px;font-weight:400;border:2px solid var(--w06);margin-bottom:12px;transition:border-color .3s}
.pcard.selected .pcard-avatar,.pcard:hover .pcard-avatar{border-color:var(--or)}
.pcard-name{font-family:'Bebas Neue',sans-serif;font-size:18px;font-weight:400;letter-spacing:0.5px;margin-bottom:3px}
.pcard-sub{font-size:11px;color:var(--muted);font-weight:300;font-style:italic;margin-bottom:12px}
.pcard-sel{display:flex;align-items:center;gap:7px;font-family:'Bebas Neue',sans-serif;font-size:10px;font-weight:400;letter-spacing:0.8px;text-transform:uppercase;color:var(--muted);transition:color .3s}
.pcard.selected .pcard-sel{color:var(--or)}
.pdot{width:15px;height:15px;border-radius:50%;border:2px solid rgba(255,92,0,.25);display:flex;align-items:center;justify-content:center;transition:all .3s;flex-shrink:0}
.pcard.selected .pdot{border-color:var(--or);background:var(--or)}
.pdot::after{content:'';width:5px;height:5px;border-radius:50%;background:var(--w);opacity:0;transition:opacity .2s}
.pcard.selected .pdot::after{opacity:1}
/* locked overlay */
.fase2-lock{padding:48px 28px;text-align:center}
.fl-icon{width:44px;height:44px;color:rgba(255,255,255,.12);margin:0 auto 14px}
.fl-title{font-family:'Bebas Neue',sans-serif;font-size:22px;font-weight:400;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.2);margin-bottom:8px}
.fl-sub{font-size:13px;color:var(--muted);line-height:1.7;font-weight:300;max-width:360px;margin:0 auto 18px}
/* progress bar */
.progress-wrap{padding:16px 28px;border-bottom:1px solid var(--w06)}
.progress-label{font-size:11px;color:var(--muted);font-weight:600;letter-spacing:1px;margin-bottom:6px;display:flex;justify-content:space-between}
.progress-bar{height:3px;background:var(--w06);position:relative}
.progress-fill{height:100%;background:linear-gradient(to right,var(--or),var(--or2));transition:width .5s ease;position:relative}
.progress-fill::after{content:'';position:absolute;right:-1px;top:50%;transform:translateY(-50%);width:7px;height:7px;border-radius:50%;background:var(--or2);box-shadow:0 0 8px var(--or)}
/* current category indicator in panels */
.cat-nav{display:flex;gap:1px;padding:14px 28px;border-bottom:1px solid var(--w06);overflow-x:auto;scrollbar-width:none}
.cat-nav::-webkit-scrollbar{display:none}
.catnav-btn{padding:6px 14px;font-family:'Bebas Neue',sans-serif;font-size:10px;font-weight:400;letter-spacing:0.8px;text-transform:uppercase;background:transparent;border:1px solid var(--w06);color:var(--muted);cursor:pointer;transition:all .2s;white-space:nowrap;flex-shrink:0}
.catnav-btn:hover{border-color:rgba(255,92,0,.25);color:var(--w)}
.catnav-btn.active{border-color:var(--or);color:var(--or);background:rgba(255,92,0,.07)}
.catnav-btn.done{border-color:rgba(0,192,106,.35);color:var(--green)}

/* ── PAGE 4: PREMIAÇÃO ── */
#page-premiacao{}
.premio-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px}
.ptier{background:var(--card);border:1px solid var(--w06);padding:52px 44px;position:relative;overflow:hidden;transition:all .35s}
.ptier::before{content:'';position:absolute;top:0;left:0;right:0;height:4px}
.ptier.gold::before{background:linear-gradient(90deg,var(--gold),#FF8C00,var(--or))}
.ptier.silver::before{background:linear-gradient(90deg,var(--pu3),#A78BFA)}
.ptier:hover{transform:translateY(-3px);border-color:rgba(255,92,0,.15)}
.ptier-bg{position:absolute;right:-16px;bottom:-28px;font-family:'Bebas Neue',sans-serif;font-size:120px;font-weight:400;color:rgba(255,255,255,.022);pointer-events:none;line-height:1}
.ptier-tag{font-family:'Bebas Neue',sans-serif;font-size:10px;font-weight:400;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:10px}
.ptier.gold .ptier-tag{color:var(--gold)}
.ptier.silver .ptier-tag{color:#A78BFA}
.ptier-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(20px,2.5vw,32px);font-weight:400;letter-spacing:1.5px;text-transform:uppercase;line-height:1.1;margin-bottom:6px}
.ptier-sub{font-size:13px;font-style:italic;color:var(--muted);margin-bottom:32px;font-weight:300}
.pitem{display:flex;align-items:flex-start;gap:14px;margin-bottom:18px}
.pitem-icon{width:40px;height:40px;flex-shrink:0;background:rgba(255,92,0,.06);border:1px solid rgba(255,92,0,.12);display:flex;align-items:center;justify-content:center}
.pitem-icon svg{width:18px;height:18px;color:var(--or)}
.pitem-qty{font-family:'Bebas Neue',sans-serif;font-size:26px;font-weight:400;line-height:1}
.ptier.gold .pitem-qty{color:var(--gold)}
.ptier.silver .pitem-qty{color:#A78BFA}
.pitem-label{font-size:13px;font-weight:600;margin-bottom:2px}
.pitem-detail{font-size:12px;color:var(--muted);font-weight:300}
.ptier-cats{margin-top:24px;padding-top:20px;border-top:1px solid var(--w06)}
.ptier-cats p{font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-bottom:10px}
.pcat-item{display:flex;align-items:center;gap:7px;font-size:12px;color:rgba(255,255,255,.65);margin-bottom:6px;font-weight:300}
.pcat-item svg{width:12px;height:12px;color:var(--green);flex-shrink:0}
/* the night section */
.night-block{background:radial-gradient(ellipse 80% 60% at 50% 50%,rgba(255,92,0,.06),transparent),var(--card);border:1px solid rgba(255,184,0,.12);padding:56px;text-align:center;margin-top:2px}
.nb-trophy{width:64px;height:64px;color:var(--gold);margin:0 auto 20px;animation:floatY 5s ease-in-out infinite;filter:drop-shadow(0 0 20px rgba(255,184,0,.3))}
.nb-kicker{font-family:'Bebas Neue',sans-serif;font-size:10px;font-weight:400;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);margin-bottom:12px}
.nb-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(40px,7vw,80px);font-weight:400;letter-spacing:2.0px;text-transform:uppercase;line-height:.9;margin-bottom:16px}
.nb-sub{font-family:'Montserrat',sans-serif;font-style:italic;font-size:clamp(15px,2vw,20px);color:var(--muted);margin-bottom:24px}
.nb-copy{font-size:15px;color:rgba(255,255,255,.65);line-height:1.9;max-width:600px;margin:0 auto;font-weight:300}
.nb-pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:44px;text-align:left}
.nbp{background:rgba(255,255,255,.025);border:1px solid var(--w06);padding:26px 22px}
.nbp-icon{width:24px;height:24px;color:var(--gold);margin-bottom:10px}
.nbp-title{font-family:'Bebas Neue',sans-serif;font-size:15px;font-weight:400;letter-spacing:1.0px;text-transform:uppercase;margin-bottom:5px}
.nbp-desc{font-size:12px;color:rgba(255,255,255,.65);line-height:1.6;font-weight:300}

