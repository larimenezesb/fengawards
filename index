<!-- TOAST -->
<div class="toast" id="toast"><svg viewBox="0 0 24 24"><use href="#ic-check"/></svg><span id="toast-msg">Enviado!</span></div>


<script>
  // ── TAB NAVIGATION ──
  const pages = ['sobre','categorias','votacao','premiacao','hall'];
  function goTab(id){
    pages.forEach(p=>{
      document.getElementById('page-'+p)?.classList.remove('active');
      document.getElementById('tab-'+p)?.classList.remove('active');
    });
    document.getElementById('page-'+id)?.classList.add('active');
    document.getElementById('tab-'+id)?.classList.add('active');
    window.scrollTo({top:0,behavior:'smooth'});
  }

  // ── STATE TOGGLE (2026 / 2027) ──
  let currentState = '2026';
  function setState(s){
    currentState = s;
    document.getElementById('sbtn-2026').classList.toggle('on', s==='2026');
    document.getElementById('sbtn-2027').classList.toggle('on', s==='2027');
    if(s==='2027'){
      document.body.classList.add('s2027');
      // show fase2 panels, hide fase1
      document.getElementById('panels-fase1')?.style && (document.getElementById('panels-fase1').style.display='none');
      document.getElementById('panels-fase2')?.style && (document.getElementById('panels-fase2').style.display='block');
      // update badge
      document.querySelectorAll('.tab-badge').forEach(b=>b.textContent='VOTE JÁ');
    } else {
      document.body.classList.remove('s2027');
      document.getElementById('panels-fase1')?.style && (document.getElementById('panels-fase1').style.display='block');
      document.getElementById('panels-fase2')?.style && (document.getElementById('panels-fase2').style.display='none');
      document.querySelectorAll('.tab-badge').forEach(b=>b.textContent='ABERTO');
    }
    // toggle all state-2026/2027 elements
    document.querySelectorAll('.state-2026').forEach(el=>el.style.display = s==='2026' ? '' : 'none');
    document.querySelectorAll('.state-2027').forEach(el=>el.style.display = s==='2027' ? '' : 'none');
  }

  // ── FASE 1 PROGRESS ──
  const cats = ['rel','est','apr','rev','art','crq','gar','gol','lat','tec','torc'];
  const filled = {};
  function markDone(cat, el){
    const wasDone = filled[cat];
    filled[cat] = el.value.trim().length > 0;
    if(filled[cat] !== wasDone){
      const dot = document.getElementById('dot-'+cat);
      const item = dot?.closest('.vsb-item');
      if(dot) dot.style.background = filled[cat] ? 'var(--green)' : '';
      if(dot) dot.style.borderColor = filled[cat] ? 'var(--green)' : '';
      if(item) item.classList.toggle('done', filled[cat]);
      updateProgress();
    }
  }
  function updateProgress(){
    const count = Object.values(filled).filter(Boolean).length;
    const pct = Math.round(count/11*100);
    document.getElementById('prog-fill').style.width = pct+'%';
    document.getElementById('prog-txt').textContent = count+' / 11';
    document.getElementById('sb-progress-txt').textContent = count+' de 11 preenchidas';
  }
  function scrollToCat(cat){
    const el = document.getElementById('panel-'+cat);
    if(el) el.scrollIntoView({behavior:'smooth',block:'start'});
  }

  // ── FASE 2 ──
  function selP(card, name){
    const group = card.closest('.pcards');
    group.querySelectorAll('.pcard').forEach(c=>c.classList.remove('selected'));
    card.classList.add('selected');
    card.querySelector('input[type=radio]').checked = true;
  }
  let demoOpen = false;
  function toggleDemo(){
    demoOpen = !demoOpen;
    document.getElementById('fase2-lock-block').style.display = demoOpen ? 'none' : 'block';
    document.getElementById('fase2-demo').style.display = demoOpen ? 'block' : 'none';
    if(demoOpen) toast('Demonstração ativada — nomes fictícios');
  }

  // ── TOAST ──
  function toast(msg){
    const t = document.getElementById('toast');
    document.getElementById('toast-msg').textContent = msg;
    t.classList.add('show');
    setTimeout(()=>t.classList.remove('show'), 3800);
  }
  function submitInd(){ toast('Indicações oficiais registradas. Obrigado!') }
  function submitF2(){ toast('Voto confirmado. Que vença o melhor!') }
</script>
