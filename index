.hof-banner{background:linear-gradient(90deg,rgba(255,184,0,.07),rgba(255,255,255,.04));border:1px solid rgba(255,184,0,.14);padding:20px 28px;margin-bottom:2px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
